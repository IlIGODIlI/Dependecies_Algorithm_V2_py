# ──────────────────────────────────────────────────────
# Vela Causal Reasoning Engine — Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to `.env` and adjust as needed.
# All values shown are the defaults used when unset.

# Ollama LLM Configuration
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_CHAT=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30

# Engine Configuration
VELA_MODELS_DIR=models
VELA_MIN_STRENGTH=0.05

# Tokenizer Configuration
VELA_MAX_ENTITY_WORDS=4
